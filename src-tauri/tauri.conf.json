{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Alfred Desktop",
  "version": "0.2.1",
  "identifier": "com.alfred.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Alfred Desktop",
        "url": "/desktop-shell/index.html",
        "width": 1280,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true,
        "decorations": false,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"]
  }
}

{
  "name": "alfred-desktop",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "description": "Alfred Desktop — AI-powered portfolio analysis for retail investors",
  "scripts": {
    "dev": "node src-tauri/scripts/tauri-cli-runner.mjs dev",
    "build": "node src-tauri/scripts/tauri-cli-runner.mjs build",
    "build:windows": "node src-tauri/scripts/tauri-cli-runner.mjs build src-tauri/tauri.windows.conf.json",
    "build:macos": "node src-tauri/scripts/tauri-cli-runner.mjs build src-tauri/tauri.macos.conf.json",
    "check": "cd src-tauri && cargo check",
    "test": "cd src-tauri && cargo test",
    "test:js": "node --test test/*.test.js",
    "test:all": "npm run test:js && npm run test"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  }
}
